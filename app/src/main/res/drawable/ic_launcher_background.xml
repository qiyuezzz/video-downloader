<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- 主背景：深邃的紫色底色 -->
    <path
        android:pathData="M0,0h108v108h-108z"
        android:fillColor="#FF1A1A2E" />

    <!-- 动态流动感：左上角的极光蓝 -->
    <path android:pathData="M0,0C40,0 80,20 108,60V0H0Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="0"
                android:startY="0"
                android:endX="80"
                android:endY="60"
                android:type="linear">
                <item android:color="#4D00D2FF" android:offset="0.0" />
                <item android:color="#0000D2FF" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- 核心光晕：右下角的霓虹紫 -->
    <path android:pathData="M108,108C68,108 28,88 0,48V108H108Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="108"
                android:startY="108"
                android:endX="28"
                android:endY="48"
                android:type="linear">
                <item android:color="#667C3AED" android:offset="0.0" />
                <item android:color="#007C3AED" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- 装饰性线条：增加科技感 -->
    <path
        android:pathData="M0,20L108,80 M20,0L80,108"
        android:strokeWidth="0.3"
        android:strokeColor="#1AFFFFFF" />

</vector>
