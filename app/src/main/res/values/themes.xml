<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- 使用系统内置的 Material Light 主题 -->
    <style name="Theme.VideoDownload" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowBackground">@color/app_window_background_light</item>
        <!-- 深色模式由 Compose 主题统一控制，禁止系统再次自动改色 -->
        <item name="android:forceDarkAllowed">false</item>
    </style>
</resources>
